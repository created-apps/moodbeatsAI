# ─────────────────────────────────────────────────────────────────────────────
# MoodBeats AI — Environment Variables
# Copy to .env and fill in your values before running locally.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Secret key for signing session cookies — change this to a random string in prod
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-string

# ── Optional: Supabase (mood history persistence) ─────────────────────────────
# Without these, the app runs fine — history just won't persist between sessions.
# Sign up free at: https://supabase.com
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ── Server ────────────────────────────────────────────────────────────────────
# Render sets PORT automatically. Leave as 8000 for local dev.
PORT=8000
